      const applyLanguage = (lang) => {
        const activeLang = translations[lang] ? lang : "en";
        document.documentElement.lang = activeLang;
        document.documentElement.dir = activeLang === "ar" ? "rtl" : "ltr";
        document.body.dataset.lang = activeLang;

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          if (key && translations[activeLang][key]) {
            node.textContent = translations[activeLang][key];
          }
        });

        document.querySelectorAll("[data-lang-button]").forEach((button) => {
          button.classList.toggle("is-active", button.getAttribute("data-lang-button") === activeLang);
        });

        window.localStorage.setItem("site-language", activeLang);
      };

      const savedLanguage = window.localStorage.getItem("site-language") || "ar";
      applyLanguage(savedLanguage);

      document.querySelectorAll("[data-lang-button]").forEach((button) => {
        button.addEventListener("click", () => {
          applyLanguage(button.getAttribute("data-lang-button") || "en");
        });
      });
    </script>
