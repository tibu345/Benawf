---
import { siteConfig } from "../data/site";
---

<footer class="site-footer">
  <div class="container card site-footer__grid">
    <div>
      <div class="brand">
        <img src="/assets/masjid-benawf-logo.jpg" alt="" width="80" height="80" />
        <div>
          <div class="brand__name">{siteConfig.name}</div>
          <p class="footer-note" data-i18n="footer.description">{siteConfig.description}</p>
        </div>
      </div>
    </div>

    <div>
      <h2 class="small footer-heading" data-i18n="footer.quickLinks">Quick Links</h2>
      <nav class="footer-links" aria-label="Footer quick links">
        <a href="/programs" data-i18n="footer.volunteer">Volunteer</a>
        <a href="/contact" data-i18n="footer.supportUs">Support Us</a>
        <a href="/programs" data-i18n="footer.membership">Membership</a>
        <a href="/media" data-i18n="footer.annualReport">Annual Report</a>
      </nav>
    </div>

    <div>
      <h2 class="small footer-heading" data-i18n="footer.connect">Connect</h2>
      <div class="social-icons" aria-label="Social links">
        <a class="social-icon" href={siteConfig.facebookUrl} target="_blank" rel="noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13.5 21v-7h2.4l.4-3h-2.8V9.2c0-.9.3-1.5 1.6-1.5H16V5.1c-.2 0-.9-.1-1.9-.1-1.9 0-3.2 1.1-3.2 3.4V11H8.5v3h2.4v7h2.6Z" />
          </svg>
        </a>
        <a class="social-icon" href={siteConfig.youtubeUrl} target="_blank" rel="noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.6 7.2a2.9 2.9 0 0 0-2.1-2.1C17.7 4.6 12 4.6 12 4.6s-5.7 0-7.5.5A2.9 2.9 0 0 0 2.4 7.2 29.7 29.7 0 0 0 2 12a29.7 29.7 0 0 0 .4 4.8 2.9 2.9 0 0 0 2.1 2.1c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a2.9 2.9 0 0 0 2.1-2.1A29.7 29.7 0 0 0 22 12a29.7 29.7 0 0 0-.4-4.8ZM10 15.5v-7l6 3.5-6 3.5Z" />
          </svg>
        </a>
        <a class="social-icon" href="/contact" aria-label="Contact">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6.8A2.8 2.8 0 0 1 5.8 4h12.4A2.8 2.8 0 0 1 21 6.8v10.4a2.8 2.8 0 0 1-2.8 2.8H5.8A2.8 2.8 0 0 1 3 17.2V6.8Zm2 .2v.2l7 5 7-5V7H5Zm14 10V9.6l-6.4 4.6a1 1 0 0 1-1.2 0L5 9.6V17c0 .6.4 1 1 1h12c.6 0 1-.4 1-1Z" />
          </svg>
        </a>
      </div>
      <p class="footer-note" data-i18n="footer.note">Built as a fast static site with room for future real data sources.</p>
    </div>
  </div>
</footer>
